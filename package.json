{
  "name": "msyx-design-system",
  "version": "2.110.0",
  "private": true,
  "description": "Design system msyx.fr — visual regression tooling",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "generate-registry": "node bin/generate-registry.js",
    "generate-nav-sections": "node bin/generate-nav-sections.js",
    "generate-version-notes": "node bin/generate-version-notes.js",
    "build:graph": "bash shared/graph/build.sh",
    "test:syntax": "node tests/regression/nav-js-syntax.test.js",
    "test:version-notes": "node tests/regression/generate-version-notes.test.js",
    "test:graph-lib": "node tests/regression/graph-lib.test.js",
    "test:graph-model": "node tests/regression/graph-model.test.js",
    "test:graph-layout": "node tests/regression/graph-layout.test.js",
    "test:graph-layout-radial": "node tests/regression/graph-layout-radial.test.js",
    "test:graph-layout-layered": "node tests/regression/graph-layout-layered.test.js",
    "test:graph-viewport": "node tests/regression/graph-viewport.test.js",
    "test:graph-spanning-tree": "node tests/regression/graph-spanning-tree.test.js",
    "test:graph-edit-focus": "node tests/regression/graph-edit-focus.test.js",
    "test:graph-port-drop": "node tests/regression/graph-port-drop.test.js",
    "test:graph-history": "node tests/regression/graph-history.test.js",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:report": "playwright show-report",
    "test:a11y": "playwright test --config=playwright.a11y.config.ts",
    "test:a11y:report": "playwright show-report playwright-report-a11y"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.48.0",
    "esbuild": "^0.28.1",
    "http-server": "^14.1.1",
    "wait-on": "^9.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "lucide-static": "^1.21.0",
    "svgo": "^4.0.1"
  }
}
